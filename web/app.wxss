/**app.wxss**/
/* 全局样式重置 */
page, view, text, button, input, image, navigator {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 页面基础样式 */
page {
  /* 主色调 */
  --primary-color: #1677FF;
  
  /* 辅助色 */
  --accent-color: #1677FF;
  
  /* 中性色 - 白色基调 */
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F5F5;
  --bg-tertiary: #FAFAFA;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #E8E8E8;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-full: 9999rpx;

  /* 页面基础样式 */
  background-color: #FFFFFF;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  overflow-x: hidden;
}

/* 容器样式 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  box-sizing: border-box;
}

/* 简约白色卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  transition: all 0.3s ease;
}

.card:hover {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  cursor: pointer;
  border: none;
  outline: none;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.btn-primary {
  background: var(--primary-color);
  color: white;
  padding: var(--spacing-sm) var(--spacing-lg);
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.2);
}

.btn-primary:hover {
  box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.3);
  transform: translateY(-2rpx);
}

/* 输入框样式 */
.input {
  width: 100%;
  padding: var(--spacing-sm) var(--spacing-md);
  background: #FFFFFF;
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  transition: all 0.3s ease;
}

.input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 6rpx rgba(22, 119, 255, 0.1);
  outline: none;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

/* 文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.5s ease-out;
}

/* 加载动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.loading {
  animation: spin 1s linear infinite;
}

/* 页面加载动画 */
@keyframes cardFlyIn {
  0% {
    opacity: 0;
    transform: translateY(30rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-fly-in {
  animation: cardFlyIn 0.4s ease-out;
}

/* 卡片悬停动画 */
.card-hover {
  transition: all 0.3s ease;
}

.card-hover:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
}

.card-hover:active {
  transform: scale(0.98);
  transition: transform 0.1s ease;
}

/* 导航栏样式 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #E8E8E8;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.03);
  z-index: 999;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.3s ease;
}

.tab-bar-item .tab-bar-text {
  font-size: 24rpx;
  margin-top: 4rpx;
  transition: all 0.3s ease;
  color: #999999;
}

.tab-bar-item.active .tab-bar-text {
  color: var(--primary-color);
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8E8E8;
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--spacing-md);
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 提示框 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  z-index: 9999;
  animation: toastFade 0.3s ease;
}

@keyframes toastFade {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

/* 页面标题通用样式 */
.page-title {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.page-title h1 {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: var(--spacing-xs);
}

.page-title p {
  font-size: 26rpx;
  color: #999999;
  letter-spacing: 1rpx;
}
