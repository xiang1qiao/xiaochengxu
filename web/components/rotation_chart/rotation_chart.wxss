/* pages/rotation_chart/rotation_chart.wxss */

.swiper-container {
  margin: var(--spacing-md) 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.swiper {
  position: relative;
}

.swiper-img {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-lg);
  transition: transform 0.3s ease;
  object-fit: cover;
}

.swiper-img:active {
  transform: scale(0.98);
}

/* 简洁的指示器样式 */
.swiper .wx-swiper-dots {
  bottom: 16rpx;
  z-index: 2;
}

.swiper .wx-swiper-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  margin: 0 6rpx;
  background-color: rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.swiper .wx-swiper-dot-active {
  background-color: var(--primary-color);
  width: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.5);
}
