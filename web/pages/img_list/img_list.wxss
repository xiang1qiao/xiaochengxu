/* pages/img_list/img_list.wxss */

/* 主容器 */
.img-manage-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FDF4 0%, #F8FAFC 30%, #F1F5F9 100%);
  padding: 24rpx;
  padding-bottom: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 顶部统计栏 ===== */
.stats-bar {
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.25);
}

.stats-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.stats-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-icon .icon-svg {
  width: 36rpx;
  height: 36rpx;
  color: #FFFFFF;
}

.stats-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.stats-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.count-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.count-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 区块头部 ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon.teal {
  background: #F0FDF4;
}

.section-icon.blue {
  background: #EFF6FF;
}

.section-icon .icon-svg {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.section-icon.blue .icon-svg {
  color: #3B82F6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

.section-count {
  font-size: 24rpx;
  color: #64748B;
  margin-left: auto;
}

/* ===== 搜索筛选区 ===== */
.search-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-label {
  width: 140rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.label-icon {
  width: 28rpx;
  height: 28rpx;
  color: #64748B;
}

.form-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1E293B;
  background: #FAFAFA;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #0D9488;
  background: #FFFFFF;
}

.date-range {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #94A3B8;
  background: #FAFAFA;
}

.date-picker.active {
  color: #0D9488;
  border-color: #0D9488;
  background: #F0FDF4;
}

.picker-icon {
  width: 24rpx;
  height: 24rpx;
  color: #64748B;
}

.date-separator {
  font-size: 26rpx;
  color: #64748B;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.search-btn, .reset-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.search-btn {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(13, 148, 136, 0.25);
}

.search-btn::after, .reset-btn::after {
  border: none;
}

.reset-btn {
  background: #F8FAFC;
  color: #64748B;
  border: 2rpx solid #E2E8F0;
}

.search-btn .btn-icon, .reset-btn .btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: inherit;
}

/* ===== 列表区域 ===== */
.list-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.data-card {
  background: #F8FAFC;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.data-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
}

.file-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.file-icon {
  width: 48rpx;
  height: 48rpx;
  background: #F0FDF4;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.file-icon .icon-svg {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.file-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.filename {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.username {
  font-size: 22rpx;
  color: #64748B;
  background: #F1F5F9;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.upload-time {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

/* 图片对比区 */
.image-comparison {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.image-box {
  flex: 1;
  position: relative;
}

.card-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background: #E2E8F0;
}

.image-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background: #F1F5F9;
  border: 2rpx dashed #CBD5E1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.placeholder-icon {
  width: 48rpx;
  height: 48rpx;
  color: #94A3B8;
}

.image-placeholder text {
  font-size: 22rpx;
  color: #94A3B8;
}

.image-label {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.compare-arrow {
  width: 48rpx;
  height: 48rpx;
  background: #E0F2FE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  color: #0EA5E9;
}

/* 检测结果 */
.detection-result {
  padding: 0 24rpx 16rpx;
}

.result-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #DCFCE7;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
}

.tag-icon {
  width: 24rpx;
  height: 24rpx;
  color: #16A34A;
}

.result-text {
  font-size: 26rpx;
  color: #16A34A;
  font-weight: 500;
}

.detection-result.empty {
  text-align: center;
}

.no-result {
  font-size: 24rpx;
  color: #94A3B8;
  font-style: italic;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid #E2E8F0;
  background: #FFFFFF;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn::after {
  border: none;
}

.detect-btn {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  color: #FFFFFF;
}

.delete-btn {
  background: #FEF2F2;
  color: #DC2626;
  border: 2rpx solid #FECACA;
}

.action-btn .btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: inherit;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F1F5F9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon .icon-svg.large {
  width: 56rpx;
  height: 56rpx;
  color: #94A3B8;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ===== 分页控制 ===== */
.pagination-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.pagination-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #64748B;
}

.pagination-info .divider {
  color: #E2E8F0;
}

.pagination-controls {
  display: flex;
  gap: 16rpx;
}

.page-btn {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid #E2E8F0;
}

.page-btn::after {
  border: none;
}

.page-btn.disabled {
  background: #F1F5F9;
  color: #CBD5E1;
}

.page-btn .btn-icon {
  width: 24rpx;
  height: 24rpx;
  color: inherit;
}

/* ===== 底部版权 ===== */
.footer {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 22rpx;
  color: #94A3B8;
}

/* ===== 响应式适配 ===== */
@media (max-width: 750rpx) {
  .img-manage-container {
    padding: 16rpx;
  }

  .stats-bar {
    flex-direction: column;
    gap: 20rpx;
    padding: 24rpx;
  }

  .form-row {
    flex-direction: column;
    align-items: stretch;
  }

  .form-label {
    width: auto;
  }

  .date-range {
    flex-direction: column;
  }

  .date-separator {
    display: none;
  }

  .image-comparison {
    flex-direction: column;
  }

  .compare-arrow {
    transform: rotate(90deg);
  }

  .card-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12rpx;
  }

  .upload-time {
    align-self: flex-end;
  }
}
