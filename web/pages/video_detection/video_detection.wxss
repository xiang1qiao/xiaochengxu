/* pages/video_detection/video_detection.wxss */

/* 主容器 */
.video-detection-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FDF4 0%, #F8FAFC 30%, #F1F5F9 100%);
  padding: 24rpx;
  padding-bottom: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ===== 顶部状态栏 ===== */
.status-bar {
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.25);
}

.status-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon.detecting {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.status-icon .icon-svg {
  width: 36rpx;
  height: 36rpx;
  color: #FFFFFF;
}

.status-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.status-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.quick-stats {
  display: flex;
  gap: 32rpx;
}

.quick-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.quick-stat .stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.quick-stat .stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 区块头部 ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon.teal {
  background: #F0FDF4;
}

.section-icon.green {
  background: #DCFCE7;
}

.section-icon.blue {
  background: #EFF6FF;
}

.section-icon .icon-svg {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.section-icon.green .icon-svg {
  color: #16A34A;
}

.section-icon.blue .icon-svg {
  color: #3B82F6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

/* ===== 上传区域 ===== */
.upload-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.video-upload-area {
  width: 100%;
  min-height: 400rpx;
  border: 2rpx dashed #E2E8F0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  transition: all 0.3s ease;
  overflow: hidden;
}

.video-upload-area.has-video {
  border-style: solid;
  border-color: #0D9488;
  background: #FFFFFF;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx;
}

.upload-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.25);
}

.upload-icon .icon-svg.large {
  width: 48rpx;
  height: 48rpx;
  color: #FFFFFF;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1E293B;
}

.upload-hint {
  font-size: 22rpx;
  color: #94A3B8;
}

.video-wrapper {
  width: 100%;
  height: 400rpx;
  position: relative;
}

.preview-video {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.video-wrapper:active .video-overlay {
  opacity: 1;
}

.overlay-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}

.overlay-btn .btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.overlay-btn text {
  font-size: 26rpx;
  font-weight: 500;
  color: #0D9488;
}

.upload-actions {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background: #F8FAFC;
  color: #64748B;
  border: 2rpx solid #E2E8F0;
}

.action-btn.secondary::after {
  border: none;
}

.action-btn .btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: inherit;
}

/* ===== 检测操作区 ===== */
.action-section {
  padding: 0 24rpx;
}

.detect-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.3);
  border: none;
}

.detect-btn::after {
  border: none;
}

.detect-btn.disabled {
  background: #E2E8F0;
  box-shadow: none;
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detect-btn .btn-icon {
  width: 32rpx;
  height: 32rpx;
  color: #FFFFFF;
}

.detect-btn.disabled .btn-icon {
  color: #94A3B8;
}

.detect-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.detect-btn.disabled text {
  color: #94A3B8;
}

/* ===== 检测结果区 ===== */
.result-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.result-video-card {
  margin-bottom: 24rpx;
}

.result-video-wrapper {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F8FAFC;
  margin-bottom: 16rpx;
}

.result-video {
  width: 100%;
  height: 100%;
}

.result-video-actions {
  display: flex;
  justify-content: center;
}

.save-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #16A34A 0%, #22C55E 100%);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(22, 163, 74, 0.25);
}

.save-btn::after {
  border: none;
}

.save-btn .btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: #FFFFFF;
}

.save-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* 检测结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #E2E8F0;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.result-badge {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.confidence-bar {
  width: 100%;
  height: 8rpx;
  background: #E2E8F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.confidence-fill {
  height: 100%;
  background: linear-gradient(90deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.confidence-value {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.confidence-value .value {
  font-size: 32rpx;
  font-weight: 700;
  color: #0D9488;
}

.confidence-value .unit {
  font-size: 20rpx;
  color: #64748B;
}

.result-detail {
  padding-top: 12rpx;
  border-top: 1rpx solid #E2E8F0;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #64748B;
  white-space: nowrap;
}

.detail-value {
  font-size: 22rpx;
  color: #1E293B;
  font-family: monospace;
}

/* ===== 使用提示 ===== */
.tips-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  background: #DCFCE7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-icon .icon-svg.small {
  width: 20rpx;
  height: 20rpx;
  color: #16A34A;
}

.tip-text {
  font-size: 26rpx;
  color: #475569;
}

/* ===== 底部版权 ===== */
.footer {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 22rpx;
  color: #94A3B8;
}

/* ===== 响应式适配 ===== */
@media (max-width: 750rpx) {
  .video-detection-container {
    padding: 16rpx;
  }

  .status-bar {
    flex-direction: column;
    gap: 20rpx;
    padding: 24rpx;
  }

  .quick-stats {
    width: 100%;
    justify-content: space-around;
  }

  .video-upload-area {
    min-height: 300rpx;
  }

  .video-wrapper {
    height: 300rpx;
  }

  .result-video-wrapper {
    height: 300rpx;
  }
}
