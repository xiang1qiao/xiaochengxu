/* pages/video_detection/video_detection.wxss */

.detection-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20rpx;
    min-height: 100vh;
    background-color: #f5f5f5;
}


.video-div {
    width: 90%;
    margin: 20rpx 0;
    padding: 30rpx;
    background: white;
    border-radius: 16rpx;
    box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
}


.video-show-div { 
    height: 400rpx; 
    width: 100%;
    border: 2rpx solid #e0e0e0;
    border-radius: 12rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #f9f9f9;
    overflow: hidden;
    margin-bottom: 20rpx;
}

.placeholder {
    color: #999;
    font-size: 28rpx;
}

.video-show-css { 
    width: 100%;
    height: 100%;
}


.up-btn-group { 
    width: 100%;
    display: flex;
    justify-content: center;
}


.center-area {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 20rpx 0;
}


.result-container {
    max-height: 300rpx;
    width: 90%;
    margin-top: 20rpx;
    border: 2rpx solid #eee;
    border-radius: 12rpx;
    padding: 15rpx;
    background-color: white;
}

.placeholder-result {
    color: #bbb;
    font-size: 26rpx;
    margin-top: 20rpx;
}


.result-item {
    margin-bottom: 30rpx;
    padding-bottom: 15rpx;
    border-bottom: 1rpx dashed #eee;
}

.result-item text {
    display: block;
    font-size: 26rpx;
    margin-bottom: 8rpx;
}

.coordinate {
    margin-top: 10rpx;
    font-size: 24rpx;
    color: #666;
}


button {
    border-radius: 8rpx;
    font-size: 28rpx;
    padding: 0 30rpx;
    height: 60rpx;
    line-height: 60rpx;
}

button[type=primary] {
    background-color: #1a2980;
}

button[disabled] {
    opacity: 0.6;
}