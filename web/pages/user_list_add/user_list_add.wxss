/* pages/user_form/user_form.wxss */
.form-main {
    padding: 30rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

form {

    border-radius: 16rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.form-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 1rpx solid #eee;
}

.form-item:last-of-type {
    border-bottom: none;
}


.required .form-label::before {
    content: '*';
    color: #f56c6c;
    margin-right: 8rpx;
}

.form-label {
    width: 140rpx;
   
    font-size: 28rpx;
    color: #333;
    flex-shrink: 0;
    text-align: right;
    padding-right: 20rpx;
}

.form-input {
    flex: 1;
    font-size: 28rpx;
    min-height: 40rpx;
    background-color: #ffffff;
    border: 1px solid rgb(201, 197, 197);
    border-radius: 20rpx;
    padding: 8rpx;
}

.disabled-input {
    color: #999;
    background-color: #f5f5f5;
    padding: 8rpx 16rpx;
    border-radius: 6rpx;
    border: 1rpx solid #e0e0e0;
}

.picker-selector {
    flex: 1;
    font-size: 28rpx;
    color: #333;
    padding: 8rpx 16rpx;
    border: 1rpx solid #e0e0e0;
    border-radius: 6rpx;
    background-color: #f9f9f9;
}


.submit-area {
    padding: 40rpx 0;
    text-align: center;
}

.submit-btn {
    width: 80%;
    height: 80rpx;
    line-height: 80rpx;
    font-size: 32rpx;
    background-color: #3a98f7;
    color: white;
    border-radius: 10rpx;

    display: flex;
    align-items: center;
    justify-content: center;
}