<!--index.wxml-->
<view class="index-container">
  <!-- 顶部品牌区域 -->
  <view class="header-section">
    <view class="header-content">
      <view class="brand-logo">
        <view class="logo-icon-wrapper">
          <svg class="logo-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" fill="currentColor"/>
          </svg>
        </view>
        <view class="brand-text">
          <text class="logo-title">智检云</text>
          <text class="logo-subtitle">中药材智能检测平台</text>
        </view>
      </view>
      <view class="header-badge">
        <view class="badge-dot"></view>
        <text class="badge-text">系统运行正常</text>
      </view>
    </view>
    <view class="header-stats">
      <view class="stat-item">
        <text class="stat-value">{{stats.detectionCount || 0}}</text>
        <text class="stat-label">累计检测</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.accuracy || '98.5%'}}</text>
        <text class="stat-label">识别准确率</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.todayCount || 0}}</text>
        <text class="stat-label">今日检测</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能区 -->
  <view class="quick-actions">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-line"></view>
        <text class="section-title">快捷功能</text>
      </view>
    </view>
    <view class="action-grid">
      <view class="action-item primary" bindtap="navigateTo" data-url="/pages/img_detection/img_detection">
        <view class="action-icon-wrapper primary-bg">
          <svg class="action-icon" viewBox="0 0 24 24" fill="none">
            <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" fill="currentColor"/>
          </svg>
        </view>
        <text class="action-name">图片检测</text>
        <text class="action-desc">AI智能识别</text>
      </view>
      <view class="action-item" bindtap="navigateTo" data-url="/pages/video_detection/video_detection">
        <view class="action-icon-wrapper blue-bg">
          <svg class="action-icon" viewBox="0 0 24 24" fill="none">
            <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
          </svg>
        </view>
        <text class="action-name">视频检测</text>
        <text class="action-desc">批量分析</text>
      </view>
      <view class="action-item" bindtap="navigateTo" data-url="/pages/img_list/img_list">
        <view class="action-icon-wrapper green-bg">
          <svg class="action-icon" viewBox="0 0 24 24" fill="none">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor"/>
          </svg>
        </view>
        <text class="action-name">图片管理</text>
        <text class="action-desc">历史记录</text>
      </view>
      <view class="action-item" bindtap="navigateTo" data-url="/pages/video_list/video_list">
        <view class="action-icon-wrapper orange-bg">
          <svg class="action-icon" viewBox="0 0 24 24" fill="none">
            <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8 12.5v-9l6 4.5-6 4.5z" fill="currentColor"/>
          </svg>
        </view>
        <text class="action-name">视频管理</text>
        <text class="action-desc">视频库</text>
      </view>
    </view>
  </view>

  <!-- 系统公告/轮播 -->
  <view class="notice-section" wx:if="{{ImgDataList.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-line"></view>
        <text class="section-title">系统动态</text>
      </view>
    </view>
    <view class="carousel-card">
      <my-rotation-chart imgDataList="{{ImgDataList}}" />
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="title-line"></view>
        <text class="section-title">功能中心</text>
      </view>
    </view>
    <view class="menu-card">
      <my-index-menu MenuList="{{MenuList}}" />
    </view>
  </view>

  <!-- 底部版权信息 -->
  <view class="footer-section">
    <text class="footer-text">智检云 · 专业中药材检测系统</text>
    <text class="footer-version">v2.0.0</text>
  </view>
</view>
