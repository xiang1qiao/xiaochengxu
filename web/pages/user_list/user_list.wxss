/* pages/user_list/user_list.wxss */
.pages-main {
    padding: 20rpx;
    background: #f5f5f5;
    min-height: 100vh;
}


.top-area {
    margin-bottom: 30rpx;
}

.top-search {
    background: white;
    padding: 30rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-form {
    display: flex;
    flex-wrap: wrap;
    gap: 20rpx;
}

.form-item {
    display: flex;
    align-items: center;
    flex-basis: calc(50% - 10rpx);
}

.form-label {
    width: 100rpx;
    font-size: 28rpx;
    color: #333;
    flex-shrink: 0;
}

.form-input {
    flex: 1;
    border: 2rpx solid #ddd;
    border-radius: 8rpx;
    padding: 16rpx 20rpx;
    font-size: 28rpx;
}

.search-btn {
    background: #409eff;
    color: white;
    border: none;
    border-radius: 8rpx;
    font-size: 28rpx;
    max-width: 300rpx;
    height: 72rpx;
    line-height: 72rpx;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}


.button-group {
    display: flex;
    justify-content: flex-end;
    gap: 20rpx;
}

.batch-delete-btn {
    background: #f56c6c;
    color: white;
    font-size: 28rpx;
    padding: 0 30rpx;
    height: 72rpx;
    line-height: 72rpx;
}

.add-btn {
    background: #67c23a;
    color: white;
    font-size: 28rpx;
    padding: 0 30rpx;
    height: 72rpx;
    line-height: 72rpx;
}


.card-list {
    margin-top: 30rpx;
}

.data-card {
    background: white;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
    overflow: hidden;
}

.card-header {
    display: flex;
    align-items: center;
    padding: 24rpx 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    background: #fafafa;
}

.card-checkbox {
    margin-right: 20rpx;
    transform: scale(0.8);
}

.card-title {
    flex: 1;
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
}

.card-level {
    font-size: 24rpx;
    padding: 6rpx 16rpx;
    border-radius: 8rpx;
    color: white;
}

.level-1 {
    background-color: #409eff;
}

.level-10 {
    background-color: #e6a23c;
}

.card-content {
    padding: 24rpx 30rpx;
}

.card-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.card-row:last-child {
    margin-bottom: 0;
}

.label {
    font-size: 28rpx;
    color: #999;
    min-width: 120rpx;
}

.value {
    font-size: 28rpx;
    color: #333;
    text-align: right;
    flex: 1;
}


.card-actions {
    display: flex;
    justify-content: flex-end;
    padding: 20rpx 30rpx;
    border-top: 1rpx solid #f0f0f0;
    gap: 16rpx;
}

.action-btn {
    height: 60rpx;
    line-height: 60rpx;
    font-size: 26rpx;
    padding: 0 24rpx;
    border-radius: 8rpx;
    margin: 0;
}

.primary-btn {
    background: #409eff;
    color: white;
}

.delete-btn {
    background: #f56c6c;
    color: white;
}


.empty-state,
.loading-state {
    text-align: center;
    padding: 80rpx 30rpx;
    color: #999;
    font-size: 30rpx;
}






.pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    padding: 20rpx 30rpx;
    border-radius: 16rpx;
    margin-top: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
    flex-wrap: wrap;
}

.pagination-info {
    font-size: 26rpx;
    color: #666;
    flex-shrink: 0;
    margin-right: 20rpx;
}

.pagination-controls {
    display: flex;
    align-items: center;
    gap: 10rpx;
    flex-wrap: wrap;
    justify-content: flex-end;
    flex-grow: 1;
    min-width: 0;
}

.pagination-btn {

    padding: 0 8rpx;
    height: 56rpx;
    line-height: 56rpx;
    max-width: 160rpx;
    border: 2rpx solid #409eff;
    border-radius: 8rpx;
    background: white;
    color: #409eff;
    font-size: 24rpx;
    margin: 0;
    flex-shrink: 0;
}

.pagination-btn[disabled] {
    border-color: #ccc;
    color: #ccc;
}

.pagination-current {
    font-size: 26rpx;
    color: #333;
    padding: 0 10rpx;
    flex-shrink: 0;
}