<!--pages/user_list/user_list.wxml-->
<view class="user-manage-container">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-content">
      <view class="nav-left">
        <view class="nav-icon">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
          </svg>
        </view>
        <view class="nav-title-group">
          <text class="nav-title">用户管理中心</text>
          <text class="nav-subtitle">User Management</text>
        </view>
      </view>
      <view class="nav-right">
        <view class="stats-badge">
          <text class="badge-count">{{total || 0}}</text>
          <text class="badge-label">位用户</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作栏 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="onSearch">
      <view class="action-icon search">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">搜索</text>
    </view>
    <view class="action-item" bindtap="onReset">
      <view class="action-icon reset">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">重置</text>
    </view>
    <view class="action-item" bindtap="refreshData">
      <view class="action-icon refresh">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">刷新</text>
    </view>
    <view class="action-item" bindtap="add">
      <view class="action-icon add">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">新增</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="panel-header">
      <view class="panel-title">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none">
          <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" fill="currentColor"/>
        </svg>
        <text>筛选条件</text>
      </view>
      <view class="panel-toggle" bindtap="toggleFilter">
        <svg class="toggle-icon {{showFilter ? 'rotate' : ''}}" viewBox="0 0 24 24" fill="none">
          <path d="M7 10l5 5 5-5z" fill="currentColor"/>
        </svg>
      </view>
    </view>

    <view class="panel-body" wx:if="{{showFilter}}">
      <!-- 账号筛选 -->
      <view class="filter-item">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
          </svg>
          <text>用户账号</text>
        </view>
        <input 
          class="filter-input" 
          placeholder="请输入账号搜索" 
          value="{{form.username}}" 
          bindinput="onUsernameInput"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- 姓名筛选 -->
      <view class="filter-item">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="currentColor"/>
          </svg>
          <text>用户姓名</text>
        </view>
        <input 
          class="filter-input" 
          placeholder="请输入姓名搜索" 
          value="{{form.name}}" 
          bindinput="onNameInput"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- 手机号筛选 -->
      <view class="filter-item">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/>
          </svg>
          <text>手机号码</text>
        </view>
        <input 
          class="filter-input" 
          placeholder="请输入手机号搜索" 
          value="{{form.phone}}" 
          bindinput="onPhoneInput"
          type="number"
          maxlength="11"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- 操作按钮 -->
      <view class="filter-actions">
        <button class="action-btn primary" bindtap="onSearch">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
          </svg>
          <text>开始搜索</text>
        </button>
        <button class="action-btn secondary" bindtap="onReset">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" fill="currentColor"/>
          </svg>
          <text>重置条件</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 用户列表 -->
  <view class="user-list-section">
    <view class="list-header">
      <view class="list-title">
        <view class="title-icon">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/>
          </svg>
        </view>
        <text>用户列表</text>
      </view>
      <text class="list-count">共 {{total}} 位</text>
    </view>

    <!-- 数据列表 -->
    <view class="user-cards" wx:if="{{dataList.length > 0}}">
      <view class="user-card" wx:for="{{dataList}}" wx:key="id">
        <!-- 卡片头部 -->
        <view class="card-top">
          <view class="card-id">
            <text class="id-label">ID</text>
            <text class="id-number">{{item.id}}</text>
          </view>
          <view class="card-level level-{{item.level}}">
            <view class="level-dot"></view>
            <text>{{levelDic[item.level]}}</text>
          </view>
        </view>

        <!-- 用户信息 -->
        <view class="card-info">
          <view class="info-avatar">
            <view class="avatar-bg">
              <text class="avatar-text">{{item.name ? item.name[0] : item.username[0]}}</text>
            </view>
          </view>
          <view class="info-content">
            <view class="info-row">
              <view class="info-item">
                <svg class="item-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
                </svg>
                <text class="item-label">账号:</text>
                <text class="item-value">{{item.username}}</text>
              </view>
            </view>
            <view class="info-row">
              <view class="info-item">
                <svg class="item-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="currentColor"/>
                </svg>
                <text class="item-label">姓名:</text>
                <text class="item-value">{{item.name || '未设置'}}</text>
              </view>
            </view>
            <view class="info-row">
              <view class="info-item">
                <svg class="item-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/>
                </svg>
                <text class="item-label">手机:</text>
                <text class="item-value">{{item.phone || '未绑定'}}</text>
              </view>
            </view>
            <view class="info-row">
              <view class="info-item">
                <svg class="item-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z" fill="currentColor"/>
                </svg>
                <text class="item-label">注册:</text>
                <text class="item-value">{{item.CreatedAt}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-actions">
          <button class="card-btn edit" bindtap="put" data-uid="{{item.uid}}">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
              <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="currentColor"/>
            </svg>
            <text>编辑</text>
          </button>
          <button class="card-btn delete" bindtap="del_fun" data-id="{{item.id}}">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
              <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
            </svg>
            <text>删除</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{dataList.length === 0 && !isLoading}}">
      <view class="empty-illustration">
        <svg class="illustration-icon" viewBox="0 0 24 24" fill="none">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
        </svg>
      </view>
      <text class="empty-title">暂无用户数据</text>
      <text class="empty-desc">点击右上角"新增"按钮添加用户</text>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 分页控制 -->
  <view class="pagination-bar" wx:if="{{dataList.length > 0}}">
    <view class="pagination-info">
      <text class="info-text">第 {{form.page}} / {{Math.ceil(total / form.pagesize)}} 页</text>
      <text class="info-divider">|</text>
      <text class="info-text">共 {{total}} 位</text>
    </view>
    <view class="pagination-btns">
      <button 
        class="page-btn prev {{form.page <= 1 ? 'disabled' : ''}}" 
        disabled="{{form.page <= 1}}"
        bindtap="prevPage"
      >
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" fill="currentColor"/>
        </svg>
        <text>上一页</text>
      </button>
      <button 
        class="page-btn next {{form.page >= Math.ceil(total / form.pagesize) ? 'disabled' : ''}}" 
        disabled="{{form.page >= Math.ceil(total / form.pagesize)}}"
        bindtap="nextPage"
      >
        <text>下一页</text>
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="currentColor"/>
        </svg>
      </button>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-bar">
    <view class="footer-content">
      <view class="footer-brand">
        <svg class="brand-icon" viewBox="0 0 24 24" fill="none">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" fill="currentColor"/>
        </svg>
        <text class="brand-text">智检云</text>
      </view>
      <text class="footer-divider">·</text>
      <text class="footer-desc">专业中药材检测系统</text>
    </view>
  </view>
</view>
