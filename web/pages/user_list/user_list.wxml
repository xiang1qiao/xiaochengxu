<view class="pages-main">
  <view class="top-area">
    <view class="top-search">
      <view class="search-form">
        <view class="form-item">
          <view class="form-label">账号:</view>
          <input 
            class="form-input" 
            placeholder="搜索账号" 
            value="{{form.username}}" 
            bindinput="onUsernameInput"
          />
        </view>
        <view class="form-item">
          <view class="form-label">姓名:</view>
          <input 
            class="form-input" 
            placeholder="搜索姓名" 
            value="{{form.name}}" 
            bindinput="onNameInput"
          />
        </view>
        <view class="form-item">
          <view class="form-label">手机号:</view>
          <input 
            class="form-input" 
            placeholder="搜索手机号" 
            value="{{form.phone}}" 
            bindinput="onPhoneInput"
          />
        </view>
        
        <view class="form-item">
          <button class="search-btn" bindtap="onSearch">搜索</button>
        </view>
      </view>
    </view>

    <view class="button-group">
     
      <button class="add-btn" bindtap="add">添加账号</button>
    </view>
  </view>

  <view class="card-list">
    <checkbox-group bindchange="onSelectionChange">
      <view 
        class="data-card" 
        wx:for="{{dataList}}" 
        wx:key="id"
      >
        <view class="card-header">
  
          <view class="card-title">{{item.username}}</view>
          <view class="card-level level-{{item.level}}">{{levelDic[item.level]}}</view>
        </view>

        <view class="card-content">
          <view class="card-row">
            <text class="label">姓名:</text>
            <text class="value">{{item.name}}</text>
          </view>
          <view class="card-row">
            <text class="label">手机号:</text>
            <text class="value">{{item.phone}}</text>
          </view>
          <view class="card-row">
            <text class="label">注册时间:</text>
            <text class="value">{{item.CreatedAt}}</text>
          </view>
        </view>

        <view class="card-actions">
          <button class="action-btn primary-btn" bindtap="put" data-uid="{{item.uid}}">修改</button>
          <button class="action-btn delete-btn" bindtap="del_fun" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </checkbox-group>

    <view wx:if="{{dataList.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-text">暂无数据</text>
    </view>
     <view wx:if="{{isLoading}}" class="loading-state">
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <view class="pagination">
    <view class="pagination-info">共 {{total}} 条</view>
    <view class="pagination-controls">
      <button 
        class="pagination-btn" 
        disabled="{{form.page <= 1}}"
        bindtap="prevPage"
      >上一页</button>
   
      <button 
        class="pagination-btn" 
        disabled="{{form.page >= totalPages}}"
        bindtap="nextPage"
      >下一页</button>
    </view>
  </view>
</view>