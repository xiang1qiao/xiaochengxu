/* pages/login/login.wxss */

/* 主容器 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 50%, #115E59 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  position: relative;
  overflow: hidden;
}

/* ===== 背景装饰 ===== */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.circle-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -200rpx;
  animation: float 20s ease-in-out infinite;
}

.circle-2 {
  width: 400rpx;
  height: 400rpx;
  bottom: -100rpx;
  left: -100rpx;
  animation: float 15s ease-in-out infinite reverse;
}

.circle-3 {
  width: 300rpx;
  height: 300rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: pulse 10s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(30rpx, 30rpx) scale(1.1);
  }
}

@keyframes pulse {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.3;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 0.1;
  }
}

/* ===== 品牌区域 ===== */
.brand-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.brand-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.brand-icon .icon-svg {
  width: 52rpx;
  height: 52rpx;
  color: #FFFFFF;
}

.brand-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.brand-slogan {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 1rpx;
}

/* ===== 登录卡片 ===== */
.login-card {
  width: 100%;
  max-width: 640rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 40rpx 32rpx;
  background: linear-gradient(180deg, #F0FDF4 0%, #FFFFFF 100%);
  border-bottom: 1rpx solid #E2E8F0;
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.3);
}

.header-icon .icon-svg {
  width: 40rpx;
  height: 40rpx;
  color: #FFFFFF;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.header-subtitle {
  font-size: 22rpx;
  color: #64748B;
  letter-spacing: 1rpx;
}

/* ===== 登录表单 ===== */
.login-form {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.item-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-icon {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.item-label text {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  height: 96rpx;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 0 80rpx 0 24rpx;
  font-size: 30rpx;
  color: #0F172A;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #0D9488;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(13, 148, 136, 0.1);
}

.input-placeholder {
  color: #94A3B8;
  font-size: 28rpx;
}

.input-clear,
.input-toggle {
  position: absolute;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.clear-icon,
.toggle-icon {
  width: 28rpx;
  height: 28rpx;
  color: #94A3B8;
  transition: color 0.3s ease;
}

.input-clear:active .clear-icon,
.input-toggle:active .toggle-icon {
  color: #0D9488;
}

/* ===== 登录按钮 ===== */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #E2E8F0;
  border: none;
  border-radius: 16rpx;
  margin-top: 16rpx;
  margin-left: 0;
  margin-right: 0;
  margin-bottom: 0;
  padding: 0;
  transition: all 0.3s ease;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-btn.active {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.35);
}

.login-btn.active:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(13, 148, 136, 0.35);
}

.login-btn.loading {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  opacity: 0.8;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-content text {
  font-size: 32rpx;
  font-weight: 600;
  color: #94A3B8;
}

.login-btn.active .btn-content text,
.login-btn.loading .btn-content text {
  color: #FFFFFF;
}

.btn-icon {
  width: 28rpx;
  height: 28rpx;
  color: #FFFFFF;
}

.btn-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ===== 表单底部 ===== */
.form-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E2E8F0;
}

.footer-text {
  font-size: 26rpx;
  color: #64748B;
}

.register-link {
  font-size: 26rpx;
  font-weight: 600;
  color: #0D9488;
}

/* ===== 底部区域 ===== */
.bottom-section {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.features {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.feature-icon {
  width: 28rpx;
  height: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.feature-item text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.copyright {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}
