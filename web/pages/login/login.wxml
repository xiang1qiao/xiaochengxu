<!--pages/login/login.wxml-->
<view class="login-container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle circle-1"></view>
    <view class="bg-circle circle-2"></view>
    <view class="bg-circle circle-3"></view>
  </view>

  <!-- 顶部品牌区域 -->
  <view class="brand-section">
    <view class="brand-icon">
      <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" fill="currentColor"/>
      </svg>
    </view>
    <view class="brand-info">
      <text class="brand-name">智检云</text>
      <text class="brand-slogan">专业中药材检测系统</text>
    </view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 卡片头部 -->
    <view class="card-header">
      <view class="header-icon">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
        </svg>
      </view>
      <view class="header-content">
        <text class="header-title">欢迎登录</text>
        <text class="header-subtitle">Welcome Back</text>
      </view>
    </view>

    <!-- 登录表单 -->
    <view class="login-form">
      <!-- 用户名输入 -->
      <view class="form-item">
        <view class="item-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
          </svg>
          <text>账号</text>
        </view>
        <view class="input-wrapper">
          <input 
            class="form-input" 
            type="text" 
            placeholder="请输入用户名" 
            placeholder-class="input-placeholder"
            value="{{form.username}}" 
            bindinput="handleInputChange" 
            data-field="username"
          />
          <view class="input-clear" wx:if="{{form.username}}" bindtap="clearInput" data-field="username">
            <svg class="clear-icon" viewBox="0 0 24 24" fill="none">
              <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
            </svg>
          </view>
        </view>
      </view>

      <!-- 密码输入 -->
      <view class="form-item">
        <view class="item-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" fill="currentColor"/>
          </svg>
          <text>密码</text>
        </view>
        <view class="input-wrapper">
          <input 
            class="form-input" 
            type="{{showPassword ? 'text' : 'password'}}" 
            placeholder="请输入密码" 
            placeholder-class="input-placeholder"
            value="{{form.password}}" 
            bindinput="handleInputChange" 
            data-field="password"
          />
          <view class="input-toggle" bindtap="togglePassword">
            <svg class="toggle-icon" viewBox="0 0 24 24" fill="none">
              <block wx:if="{{showPassword}}">
                <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" fill="currentColor"/>
              </block>
              <block wx:else>
                <path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" fill="currentColor"/>
              </block>
            </svg>
          </view>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-btn {{isLoading ? 'loading' : ''}} {{form.username && form.password ? 'active' : ''}}" 
        bindtap="login" 
        disabled="{{isLoading}}"
      >
        <view class="btn-content">
          <view class="btn-spinner" wx:if="{{isLoading}}"></view>
          <text>{{isLoading ? '登录中...' : '登 录'}}</text>
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" wx:if="{{!isLoading}}">
            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" fill="currentColor"/>
          </svg>
        </view>
      </button>

      <!-- 注册链接 -->
      <view class="form-footer">
        <text class="footer-text">还没有账号？</text>
        <navigator url="/pages/register/register" class="register-link">立即注册</navigator>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="bottom-section">
    <view class="features">
      <view class="feature-item">
        <svg class="feature-icon" viewBox="0 0 24 24" fill="none">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
        </svg>
        <text>智能识别</text>
      </view>
      <view class="feature-item">
        <svg class="feature-icon" viewBox="0 0 24 24" fill="none">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" fill="currentColor"/>
        </svg>
        <text>安全可靠</text>
      </view>
      <view class="feature-item">
        <svg class="feature-icon" viewBox="0 0 24 24" fill="none">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" fill="currentColor"/>
        </svg>
        <text>专业检测</text>
      </view>
    </view>
    <text class="copyright">© 2024 智检云 · 专业中药材检测系统</text>
  </view>
</view>
