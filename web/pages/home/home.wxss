.home-container {
  padding: var(--spacing-md);
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

/* 用户信息卡片 */
.user-info-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: var(--spacing-lg);
  overflow: hidden;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-md);
  border-bottom: 1rpx solid #E8E8E8;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-right: var(--spacing-md);
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.user-basic-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: var(--spacing-xs);
  display: block;
}

.user-role {
  font-size: 26rpx;
  color: var(--primary-color);
  background: rgba(22, 119, 255, 0.1);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  display: inline-block;
  font-weight: 500;
}

.user-details {
  padding-top: var(--spacing-sm);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #FAFAFA;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  color: #999999;
  font-weight: 500;
}

.detail-value {
  color: #333333;
  font-weight: 500;
}

/* 编辑表单卡片 */
.edit-form-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: var(--spacing-lg);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: var(--spacing-lg);
  display: block;
}

.form-group {
  margin-bottom: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.submit-btn {
  width: 100%;
  margin-top: var(--spacing-lg);
  padding: var(--spacing-md);
  font-size: 32rpx;
  font-weight: 500;
  border-radius: var(--radius-md);
  background: var(--primary-color);
  color: white;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.2);
  transition: all 0.3s ease;
}

.submit-btn:hover {
  box-shadow: 0 6rpx 16rpx rgba(22, 119, 255, 0.3);
  transform: translateY(-2rpx);
}

.submit-btn:active {
  transform: scale(0.98);
}

/* 响应式布局 */
@media (max-width: 750rpx) {
  .home-container {
    padding: var(--spacing-sm);
  }
  
  .user-header {
    flex-direction: column;
    text-align: center;
  }
  
  .user-avatar {
    margin-right: 0;
    margin-bottom: var(--spacing-md);
  }
}
