/* pages/home/home.wxss */

/* 主容器 */
.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0FDF4 0%, #F8FAFC 30%, #F1F5F9 100%);
  padding-bottom: 48rpx;
}

/* ===== 顶部用户信息区 ===== */
.profile-header {
  position: relative;
  padding: 0 24rpx;
  padding-top: 24rpx;
  margin-bottom: 32rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.user-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.user-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid #F0FDF4;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
}

.badge-icon {
  width: 20rpx;
  height: 20rpx;
  color: #FFFFFF;
}

.user-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
}

.level-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.level-tag.user {
  background: #F1F5F9;
  color: #64748B;
}

.level-tag.admin {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  color: #FFFFFF;
}

.user-id {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 用户统计 */
.user-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, #F0FDF4 0%, #ECFDF5 100%);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #0D9488;
}

.stat-label {
  font-size: 22rpx;
  color: #64748B;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #E2E8F0;
}

/* ===== 区块卡片 ===== */
.section-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon.blue {
  background: #EFF6FF;
}

.section-icon.green {
  background: #F0FDF4;
}

.section-icon.orange {
  background: #FFF7ED;
}

.icon-svg {
  width: 28rpx;
  height: 28rpx;
  color: #0D9488;
}

.section-icon.blue .icon-svg {
  color: #3B82F6;
}

.section-icon.orange .icon-svg {
  color: #F59E0B;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

/* ===== 信息列表 ===== */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-label {
  font-size: 28rpx;
  color: #64748B;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-value {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

.edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8FAFC;
  border-radius: 50%;
}

.edit-icon {
  width: 24rpx;
  height: 24rpx;
  color: #94A3B8;
}

.edit-btn:active {
  background: #F1F5F9;
}

/* ===== 菜单列表 ===== */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
  cursor: pointer;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  opacity: 0.7;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon.blue-bg {
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.25);
}

.menu-icon.orange-bg {
  background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.25);
}

.menu-icon.purple-bg {
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.25);
}

.menu-icon.teal-bg {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  box-shadow: 0 4rpx 12rpx rgba(13, 148, 136, 0.25);
}

.menu-svg {
  width: 32rpx;
  height: 32rpx;
  color: #FFFFFF;
}

.menu-text {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-svg {
  width: 24rpx;
  height: 24rpx;
  color: #CBD5E1;
}

/* ===== 退出登录按钮 ===== */
.logout-section {
  margin: 32rpx 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: #FFFFFF;
  border: 2rpx solid #FEE2E2;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #FEF2F2;
}

.logout-icon {
  width: 32rpx;
  height: 32rpx;
  color: #EF4444;
}

.logout-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #EF4444;
}

/* ===== 底部版权 ===== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 22rpx;
  color: #94A3B8;
}

.footer-version {
  font-size: 20rpx;
  color: #CBD5E1;
}

/* ===== 弹窗样式 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F1F5F9;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  color: #64748B;
}

.modal-body {
  padding: 32rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

.modal-input:focus {
  border-color: #0D9488;
}

.modal-footer {
  display: flex;
  padding: 0 32rpx 32rpx;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel {
  background: #F1F5F9;
  color: #64748B;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
  color: #FFFFFF;
}

.btn-confirm::after {
  border: none;
}

/* ===== 响应式适配 ===== */
@media (max-width: 750rpx) {
  .profile-header {
    padding: 0 20rpx;
    padding-top: 20rpx;
  }

  .user-card {
    padding: 24rpx;
  }

  .user-name {
    font-size: 32rpx;
  }

  .section-card {
    margin: 0 20rpx 20rpx;
    padding: 20rpx;
  }

  .stat-num {
    font-size: 28rpx;
  }
}
