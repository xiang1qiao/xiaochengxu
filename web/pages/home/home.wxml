<!--pages/home/home.wxml-->
<view class="profile-container">
  <!-- 顶部用户信息卡片 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="user-card">
      <view class="user-main">
        <view class="avatar-wrapper">
          <image src="{{userInfo.img || '/assets/img/login_icon.jpg'}}" mode="aspectFill" class="avatar"></image>
          <view class="avatar-badge" wx:if="{{userInfo.level >= 10}}">
            <svg class="badge-icon" viewBox="0 0 24 24" fill="none">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" fill="currentColor"/>
            </svg>
          </view>
        </view>
        <view class="user-info">
          <view class="name-row">
            <text class="user-name">{{userInfo.name || userInfo.username || '未设置昵称'}}</text>
            <view class="level-tag {{userInfo.level >= 10 ? 'admin' : 'user'}}">
              {{levelDic[userInfo.level] || '普通用户'}}
            </view>
          </view>
          <text class="user-id">ID: {{userInfo.id || '--'}}</text>
        </view>
      </view>
      
      <!-- 用户统计 -->
      <view class="user-stats">
        <view class="stat-box">
          <text class="stat-num">{{userStats.detectionCount || 0}}</text>
          <text class="stat-label">检测次数</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-box">
          <text class="stat-num">{{userStats.imgCount || 0}}</text>
          <text class="stat-label">图片检测</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-box">
          <text class="stat-num">{{userStats.videoCount || 0}}</text>
          <text class="stat-label">视频检测</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 账号信息区 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-icon blue">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
        </svg>
      </view>
      <text class="section-title">账号信息</text>
    </view>
    
    <view class="info-list">
      <view class="info-item">
        <view class="item-left">
          <text class="item-label">用户名</text>
        </view>
        <view class="item-right">
          <text class="item-value">{{userInfo.username || '-'}}</text>
        </view>
      </view>
      <view class="info-item">
        <view class="item-left">
          <text class="item-label">手机号码</text>
        </view>
        <view class="item-right">
          <text class="item-value">{{userInfo.phone || '未绑定'}}</text>
          <view class="edit-btn" bindtap="showEditModal" data-field="phone">
            <svg class="edit-icon" viewBox="0 0 24 24" fill="none">
              <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="currentColor"/>
            </svg>
          </view>
        </view>
      </view>
      <view class="info-item">
        <view class="item-left">
          <text class="item-label">注册时间</text>
        </view>
        <view class="item-right">
          <text class="item-value">{{userInfo.createdAt || '-'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单区 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-icon green">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="currentColor"/>
        </svg>
      </view>
      <text class="section-title">功能设置</text>
    </view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/img_list/img_list">
        <view class="menu-left">
          <view class="menu-icon blue-bg">
            <svg class="menu-svg" viewBox="0 0 24 24" fill="none">
              <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" fill="currentColor"/>
            </svg>
          </view>
          <text class="menu-text">我的图片</text>
        </view>
        <view class="menu-arrow">
          <svg class="arrow-svg" viewBox="0 0 24 24" fill="none">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" fill="currentColor"/>
          </svg>
        </view>
      </view>
      
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/video_list/video_list">
        <view class="menu-left">
          <view class="menu-icon orange-bg">
            <svg class="menu-svg" viewBox="0 0 24 24" fill="none">
              <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
            </svg>
          </view>
          <text class="menu-text">我的视频</text>
        </view>
        <view class="menu-arrow">
          <svg class="arrow-svg" viewBox="0 0 24 24" fill="none">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" fill="currentColor"/>
          </svg>
        </view>
      </view>
      
      <view class="menu-item" wx:if="{{userInfo.level >= 10}}" bindtap="navigateTo" data-url="/pages/user_list/user_list">
        <view class="menu-left">
          <view class="menu-icon purple-bg">
            <svg class="menu-svg" viewBox="0 0 24 24" fill="none">
              <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="currentColor"/>
            </svg>
          </view>
          <text class="menu-text">用户管理</text>
        </view>
        <view class="menu-arrow">
          <svg class="arrow-svg" viewBox="0 0 24 24" fill="none">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" fill="currentColor"/>
          </svg>
        </view>
      </view>
    </view>
  </view>

  <!-- 安全设置区 -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-icon orange">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" fill="currentColor"/>
        </svg>
      </view>
      <text class="section-title">安全设置</text>
    </view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="showPasswordModal">
        <view class="menu-left">
          <view class="menu-icon teal-bg">
            <svg class="menu-svg" viewBox="0 0 24 24" fill="none">
              <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" fill="currentColor"/>
            </svg>
          </view>
          <text class="menu-text">修改密码</text>
        </view>
        <view class="menu-arrow">
          <svg class="arrow-svg" viewBox="0 0 24 24" fill="none">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" fill="currentColor"/>
          </svg>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">
      <svg class="logout-icon" viewBox="0 0 24 24" fill="none">
        <path d="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="currentColor"/>
      </svg>
      <text class="logout-text">退出登录</text>
    </button>
  </view>

  <!-- 底部版权 -->
  <view class="footer">
    <text class="footer-text">智检云 · 专业中药材检测系统</text>
    <text class="footer-version">v2.0.0</text>
  </view>
</view>

<!-- 编辑弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal"></view>
<view class="modal-content" wx:if="{{showModal}}">
  <view class="modal-header">
    <text class="modal-title">{{modalTitle}}</text>
    <view class="modal-close" bindtap="hideModal">
      <svg class="close-icon" viewBox="0 0 24 24" fill="none">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
      </svg>
    </view>
  </view>
  <view class="modal-body">
    <input 
      type="{{modalField === 'phone' ? 'number' : 'text'}}" 
      placeholder="请输入{{modalTitle}}" 
      value="{{modalValue}}" 
      bindinput="onModalInput"
      class="modal-input"
      focus="{{showModal}}"
    />
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="hideModal">取消</button>
    <button class="btn-confirm" bindtap="confirmEdit">确认</button>
  </view>
</view>
