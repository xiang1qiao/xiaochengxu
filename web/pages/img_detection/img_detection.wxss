/* pages/img_detection/img_detection.wxss */

.detection-main {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-md);
    min-height: 100vh;
    background-color: var(--bg-secondary);
    gap: var(--spacing-lg);
}

/* 卡片样式 */
.upload-card,
.detection-card,
.result-card {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    animation: cardFlyIn 0.5s ease-out;
}

.upload-card {
    animation-delay: 0.1s;
}

.detection-card {
    animation-delay: 0.2s;
}

.result-card {
    animation-delay: 0.3s;
}

/* 卡片头部 */
.card-header {
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1rpx solid var(--border-color);
}

.card-title {
    font-size: 32rpx;
    font-weight: 600;
    color: var(--text-primary);
    display: block;
    margin-bottom: var(--spacing-xs);
}

.card-subtitle {
    font-size: 24rpx;
    color: var(--text-tertiary);
    display: block;
}

/* 图片区域 */
.img-div {
    width: 100%;
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
}

.img-show-div {
    height: 400rpx;
    width: 400rpx;
    border: 2rpx dashed var(--border-color);
    border-radius: var(--radius-lg);
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--bg-tertiary);
    overflow: hidden;
    transition: all 0.3s ease;
    cursor: pointer;
}

.img-show-div:hover {
    border-color: var(--primary-color);
    background-color: rgba(59, 130, 246, 0.05);
}

.placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--text-tertiary);
    font-size: 26rpx;
    cursor: pointer;
    transition: all 0.3s ease;
}

.placeholder:hover {
    color: var(--primary-color);
    transform: scale(1.05);
}

.placeholder-icon {
    font-size: 80rpx;
    margin-bottom: var(--spacing-sm);
}

.placeholder-text {
    font-size: 26rpx;
    text-align: center;
}

.img-show-css {
    max-width: 100%;
    max-height: 100%;
    border-radius: var(--radius-md);
    transition: transform 0.3s ease;
}

.img-show-css:hover {
    transform: scale(1.02);
}

/* 按钮区域 */
.up-img {
    width: 100%;
    display: flex;
    justify-content: center;
}

/* 检测控制区域 */
.center-area {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
}

.detection-btn {
    width: 100%;
    max-width: 300rpx;
}

/* 结果区域 */
.result-section {
    width: 100%;
    margin-top: var(--spacing-md);
}

.section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    display: block;
}

.result-container {
    max-height: 400rpx;
    width: 100%;
    border: 1rpx solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    background-color: var(--bg-primary);
    box-shadow: var(--shadow-sm);
}

.result-item {
    background-color: var(--bg-primary);
    border: 1rpx solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-md);
    transition: all 0.3s ease;
}

.result-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2rpx);
}

.result-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
}

.result-type {
    font-size: 26rpx;
    font-weight: 600;
    color: var(--primary-color);
}

.result-confidence {
    font-size: 24rpx;
    color: var(--text-secondary);
    background-color: rgba(59, 130, 246, 0.1);
    padding: 4rpx 12rpx;
    border-radius: var(--radius-full);
}

.result-item-body {
    margin-top: var(--spacing-sm);
}

.result-label {
    font-size: 24rpx;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-xs);
    display: block;
}

.coordinate {
    font-size: 22rpx;
    color: var(--text-tertiary);
    background-color: var(--bg-tertiary);
    padding: var(--spacing-sm);
    border-radius: var(--radius-sm);
    line-height: 1.4;
}

/* AI建议 */
.ai-suggestion {
    width: 100%;
    margin-top: var(--spacing-md);
    padding: var(--spacing-md);
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    border-radius: var(--radius-md);
    border-left: 4rpx solid var(--success-color);
    box-shadow: var(--shadow-sm);
}

.ai-suggestion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
}

.ai-suggestion-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #166534;
}

.ai-badge {
    font-size: 20rpx;
    font-weight: 600;
    color: white;
    background-color: var(--success-color);
    padding: 4rpx 12rpx;
    border-radius: var(--radius-full);
}

.ai-suggestion-content {
    font-size: 24rpx;
    line-height: 1.6;
    color: #1e3a8a;
    white-space: pre-wrap;
}

/* 预览模态框 */
.preview-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.9);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
    animation: fadeIn 0.3s ease;
}

.preview-image {
    width: 90%;
    height: 70vh;
    border-radius: var(--radius-md);
}

/* 响应式布局 */
@media (max-width: 750rpx) {
    .detection-main {
        padding: var(--spacing-sm);
    }
    
    .img-show-div {
        height: 300rpx;
        width: 300rpx;
    }
    
    .card-header {
        padding: var(--spacing-sm) var(--spacing-md);
    }
    
    .card-title {
        font-size: 28rpx;
    }
    
    .card-subtitle {
        font-size: 22rpx;
    }
    
    .img-div {
        padding: var(--spacing-md);
    }
    
    .center-area {
        padding: var(--spacing-md);
    }
}