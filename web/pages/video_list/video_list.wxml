<!--pages/video_list/video_list.wxml-->
<view class="video-manage-container">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-content">
      <view class="nav-left">
        <view class="nav-icon">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
            <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
          </svg>
        </view>
        <view class="nav-title-group">
          <text class="nav-title">视频管理中心</text>
          <text class="nav-subtitle">Video Management</text>
        </view>
      </view>
      <view class="nav-right">
        <view class="stats-badge">
          <text class="badge-count">{{total || 0}}</text>
          <text class="badge-label">条记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作栏 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="onSearch">
      <view class="action-icon search">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">搜索</text>
    </view>
    <view class="action-item" bindtap="onReset">
      <view class="action-icon reset">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">重置</text>
    </view>
    <view class="action-item" bindtap="refreshData">
      <view class="action-icon refresh">
        <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
          <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" fill="currentColor"/>
        </svg>
      </view>
      <text class="action-text">刷新</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="panel-header">
      <view class="panel-title">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none">
          <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" fill="currentColor"/>
        </svg>
        <text>筛选条件</text>
      </view>
      <view class="panel-toggle" bindtap="toggleFilter">
        <svg class="toggle-icon {{showFilter ? 'rotate' : ''}}" viewBox="0 0 24 24" fill="none">
          <path d="M7 10l5 5 5-5z" fill="currentColor"/>
        </svg>
      </view>
    </view>

    <view class="panel-body" wx:if="{{showFilter}}">
      <!-- 账号筛选（仅管理员） -->
      <view class="filter-item" wx:if="{{level == 10}}">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
          </svg>
          <text>用户账号</text>
        </view>
        <input 
          class="filter-input" 
          placeholder="请输入账号搜索" 
          value="{{form.username}}" 
          bindinput="onUsernameInput"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- 文件名筛选 -->
      <view class="filter-item">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" fill="currentColor"/>
          </svg>
          <text>文件名称</text>
        </view>
        <input 
          class="filter-input" 
          placeholder="请输入文件名搜索" 
          value="{{form.file_name}}" 
          bindinput="onFileNameInput"
          placeholder-class="input-placeholder"
        />
      </view>

      <!-- 时间范围 -->
      <view class="filter-item">
        <view class="filter-label">
          <svg class="label-icon" viewBox="0 0 24 24" fill="none">
            <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z" fill="currentColor"/>
          </svg>
          <text>上传时间</text>
        </view>
        <view class="date-range-picker">
          <picker 
            mode="date" 
            value="{{form.created_at_start}}" 
            start="2020-01-01"
            end="2030-12-31"
            bindchange="onStartDateChange"
          >
            <view class="date-btn {{form.created_at_start ? 'active' : ''}}">
              <text>{{form.created_at_start || '开始日期'}}</text>
              <svg class="date-icon" viewBox="0 0 24 24" fill="none">
                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
              </svg>
            </view>
          </picker>
          <view class="date-separator">
            <view class="separator-line"></view>
          </view>
          <picker 
            mode="date" 
            value="{{form.created_at_end}}" 
            start="2020-01-01"
            end="2030-12-31"
            bindchange="onEndDateChange"
          >
            <view class="date-btn {{form.created_at_end ? 'active' : ''}}">
              <text>{{form.created_at_end || '结束日期'}}</text>
              <svg class="date-icon" viewBox="0 0 24 24" fill="none">
                <path d="M7 10l5 5 5-5z" fill="currentColor"/>
              </svg>
            </view>
          </picker>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="filter-actions">
        <button class="action-btn primary" bindtap="onSearch">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
          </svg>
          <text>开始搜索</text>
        </button>
        <button class="action-btn secondary" bindtap="onReset">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
            <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" fill="currentColor"/>
          </svg>
          <text>重置条件</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 视频列表 -->
  <view class="video-list-section">
    <view class="list-header">
      <view class="list-title">
        <view class="title-icon">
          <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
            <path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9h-4v4h-2v-4H9V9h4V5h2v4h4v2z" fill="currentColor"/>
          </svg>
        </view>
        <text>检测记录</text>
      </view>
      <text class="list-count">共 {{total}} 条</text>
    </view>

    <!-- 数据列表 -->
    <view class="video-cards" wx:if="{{dataList.length > 0}}">
      <view class="video-card" wx:for="{{dataList}}" wx:key="id">
        <!-- 卡片头部 -->
        <view class="card-top">
          <view class="card-id">
            <text class="id-label">NO.</text>
            <text class="id-number">{{item.id}}</text>
          </view>
          <view class="card-time">{{item.CreatedAt}}</view>
        </view>

        <!-- 文件信息 -->
        <view class="card-info">
          <view class="info-icon">
            <svg class="icon-svg" viewBox="0 0 24 24" fill="none">
              <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
            </svg>
          </view>
          <view class="info-content">
            <text class="info-filename">{{item.file_name}}</text>
            <text class="info-username" wx:if="{{level == 10}}">{{item.username}}</text>
          </view>
        </view>

        <!-- 视频对比展示 -->
        <view class="video-compare">
          <view class="compare-item" bindtap="playVideo" data-src="{{videoLinkGet + item.mid_raw}}">
            <view class="compare-header">
              <view class="compare-dot original"></view>
              <text class="compare-label">原视频</text>
            </view>
            <view class="compare-preview">
              <video 
                wx:if="{{item.mid_raw}}" 
                src="{{videoLinkGet + item.mid_raw}}" 
                class="preview-video"
                controls="{{false}}"
                show-center-play-btn="{{false}}"
                object-fit="cover"
                poster="{{videoLinkGet + item.mid_raw + '?vframe/jpg/offset/0'}}"
              />
              <view wx:else class="preview-empty">
                <svg class="empty-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
                </svg>
                <text>暂无视频</text>
              </view>
              <view class="play-button" wx:if="{{item.mid_raw}}">
                <svg class="play-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M8 5v14l11-7z" fill="currentColor"/>
                </svg>
              </view>
            </view>
          </view>

          <view class="compare-arrow">
            <svg class="arrow-icon" viewBox="0 0 24 24" fill="none">
              <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" fill="currentColor"/>
            </svg>
          </view>

          <view class="compare-item" bindtap="playVideo" data-src="{{videoLinkGet + item.mid_handle}}">
            <view class="compare-header">
              <view class="compare-dot processed"></view>
              <text class="compare-label">检测视频</text>
            </view>
            <view class="compare-preview">
              <video 
                wx:if="{{item.mid_handle}}" 
                src="{{videoLinkGet + item.mid_handle}}" 
                class="preview-video"
                controls="{{false}}"
                show-center-play-btn="{{false}}"
                object-fit="cover"
                poster="{{videoLinkGet + item.mid_handle + '?vframe/jpg/offset/0'}}"
              />
              <view wx:else class="preview-empty">
                <svg class="empty-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
                </svg>
                <text>待检测</text>
              </view>
              <view class="play-button" wx:if="{{item.mid_handle}}">
                <svg class="play-icon" viewBox="0 0 24 24" fill="none">
                  <path d="M8 5v14l11-7z" fill="currentColor"/>
                </svg>
              </view>
            </view>
          </view>
        </view>

        <!-- 检测结果 -->
        <view class="detection-result" wx:if="{{item.item}}">
          <view class="result-badge success">
            <svg class="badge-icon" viewBox="0 0 24 24" fill="none">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/>
            </svg>
            <text>{{item.item}}</text>
          </view>
        </view>
        <view class="detection-result empty" wx:else>
          <view class="result-badge pending">
            <svg class="badge-icon" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/>
            </svg>
            <text>等待检测</text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="card-actions">
          <button class="card-btn detect" bindtap="onDetection" data-item="{{item}}">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
              <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
            </svg>
            <text>重新检测</text>
          </button>
          <button class="card-btn delete" bindtap="onDelete" data-item="{{item}}">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
              <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/>
            </svg>
            <text>删除记录</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{dataList.length === 0}}">
      <view class="empty-illustration">
        <svg class="illustration-icon" viewBox="0 0 24 24" fill="none">
          <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="currentColor"/>
        </svg>
      </view>
      <text class="empty-title">暂无视频记录</text>
      <text class="empty-desc">上传视频进行检测后，记录将显示在这里</text>
      <view class="empty-action">
        <text class="action-hint">前往视频检测页面上传视频</text>
      </view>
    </view>
  </view>

  <!-- 分页控制 -->
  <view class="pagination-bar" wx:if="{{dataList.length > 0}}">
    <view class="pagination-info">
      <text class="info-text">第 {{form.page}} / {{Math.ceil(total / form.pagesize)}} 页</text>
      <text class="info-divider">|</text>
      <text class="info-text">共 {{total}} 条</text>
    </view>
    <view class="pagination-btns">
      <button 
        class="page-btn prev {{form.page <= 1 ? 'disabled' : ''}}" 
        disabled="{{form.page <= 1}}"
        bindtap="prevPage"
      >
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" fill="currentColor"/>
        </svg>
        <text>上一页</text>
      </button>
      <button 
        class="page-btn next {{form.page >= Math.ceil(total / form.pagesize) ? 'disabled' : ''}}" 
        disabled="{{form.page >= Math.ceil(total / form.pagesize)}}"
        bindtap="nextPage"
      >
        <text>下一页</text>
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="currentColor"/>
        </svg>
      </button>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-bar">
    <view class="footer-content">
      <view class="footer-brand">
        <svg class="brand-icon" viewBox="0 0 24 24" fill="none">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z" fill="currentColor"/>
        </svg>
        <text class="brand-text">智检云</text>
      </view>
      <text class="footer-divider">·</text>
      <text class="footer-desc">专业中药材检测系统</text>
    </view>
  </view>
</view>
